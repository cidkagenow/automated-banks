GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-pro
MAYBANK_APP_PASSWORD=123456
INTERBANK_APP_PASSWORD=your-password

# Interbank account names for statement retrieval (match text in app)
VISA_INFINITE=Interbank Visa Infinite
SHADOWSAA=your-account-name
CID=your-account-name

MAC_LOGIN_PASSWORD=your-mac-password

# Interbank Web Portal (for web-based automation)
INTERBANK_DNI=your-dni-number
INTERBANK_WEB_PASSWORD=your-web-portal-password

# Interbank Web — accounts to extract statements from (comma-separated, match dashboard names)
INTERBANK_WEB_ACCOUNTS=Visa Clásica Soles,Visa Access Soles

# Yahoo Mail — used to auto-read OTP tokens sent by Interbank
# Generate an app password at https://login.yahoo.com/account/security/app-passwords
YAHOO_EMAIL=your-yahoo-email@yahoo.com
YAHOO_APP_PASSWORD=your-yahoo-app-password

# Mac login (to unlock iPhone Mirroring)
MAC_LOGIN_PASSWORD=your-mac-password

# Maybank (MAE app)
MAYBANK_APP_PASSWORD=123456

# Interbank (mobile app)
INTERBANK_APP_PASSWORD=your-password

# Interbank Web Portal (Playwright-based automation)
INTERBANK_DNI=your-dni-number
INTERBANK_WEB_PASSWORD=your-web-portal-password

# Email for OTP auto-read — supports Yahoo and Gmail
# Yahoo: generate app password at https://login.yahoo.com/account/security/app-passwords
# Gmail: generate app password at https://myaccount.google.com/apppasswords
OTP_EMAIL=your-email@yahoo.com
OTP_APP_PASSWORD=your-app-password

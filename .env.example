# Mac login (to unlock iPhone Mirroring)
MAC_LOGIN_PASSWORD=your-mac-password

# Maybank (MAE app)
MAYBANK_APP_PASSWORD=123456

# Interbank (mobile app)
INTERBANK_APP_PASSWORD=your-password

# Interbank Web Portal (Playwright-based automation)
INTERBANK_DNI=your-dni-number
INTERBANK_WEB_PASSWORD=your-web-portal-password

# Yahoo Mail — used to auto-read OTP tokens sent by Interbank
# Generate an app password at https://login.yahoo.com/account/security/app-passwords
YAHOO_EMAIL=your-yahoo-email@yahoo.com
YAHOO_APP_PASSWORD=your-yahoo-app-password
